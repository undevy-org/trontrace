# Copy to .env and fill in. .env is gitignored — never commit a real key.
# Get a key at https://www.trongrid.io/  (Console -> API Keys)

# --- Required ---
TRONGRID_API_KEY=your-trongrid-api-key-here

# --- TronGrid client (optional overrides) ---
# Free keys are capped at 15 requests/second. Stay safely below it.
TRONGRID_BASE_URL=https://api.trongrid.io
TRONGRID_MAX_RPS=12
TRONGRID_TIMEOUT_S=30
TRONGRID_MAX_RETRIES=3

# Token to analyze. Default is USDT (TRC-20).
TOKEN_SYMBOL=USDT
TOKEN_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# --- Analysis tuning (optional overrides; see app/config.py for meaning) ---
CANDIDATE_TX_CAP=5000
FANOUT_CAP=2000
FUNDING_FETCH_CAP=1000
SCORE_THRESHOLD=0.55
PAYER_WINDOW_DAYS=180

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DB_PATH=data/trontrace.db
